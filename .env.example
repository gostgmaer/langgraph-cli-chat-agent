# ============================================================
# AI Agent Platform Configuration
# Environment: Development
# ============================================================

##############################################################
# Application
##############################################################
APP_NAME=AI Agent Platform
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

##############################################################
# LLM Configuration
##############################################################
LLM_PROVIDER=google                  # google | openai | anthropic | groq | ollama

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

LLM_MODEL=gemini-2.5-flash

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192

LLM_STREAMING=true

TOP_P=0.95
TOP_K=40

##############################################################
# Ollama (Future)
##############################################################
OLLAMA_BASE_URL=http://localhost:11434

##############################################################
# Embeddings
##############################################################
EMBEDDING_PROVIDER=google             # google | openai | huggingface
EMBEDDING_MODEL=text-embedding-004

##############################################################
# Memory
##############################################################
MAX_HISTORY_MESSAGES=20

SUMMARY_TRIGGER_MESSAGES=10
SUMMARY_KEEP_LAST_MESSAGES=6

MAX_CONTEXT_TOKENS=16000

AUTO_GENERATE_SESSION_TITLE=true

SESSION_TITLE_MODEL=gemini-2.5-flash-lite

##############################################################
# Database
##############################################################
DATABASE_URL=sqlite:///data/chat.db

CHECKPOINT_DB_PATH=./data/checkpoints.db
SESSION_DB_PATH=./data/sessions.db
SUMMARY_DB_PATH=./data/summaries.db

##############################################################
# Vector Database
##############################################################
VECTOR_STORE=chroma                  # chroma | faiss | pgvector | qdrant

CHROMA_PERSIST_DIR=./data/chroma
FAISS_INDEX_PATH=./data/faiss

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=langgraph_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

##############################################################
# RAG
##############################################################
ENABLE_RAG=false

UPLOAD_DIR=./data/uploads

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

RETRIEVAL_TOP_K=5
RETRIEVAL_STRATEGY=similarity         # similarity | mmr | hybrid

##############################################################
# Tool Configuration
##############################################################
ENABLE_SEARCH_TOOL=true
ENABLE_WEATHER_TOOL=true
ENABLE_NEWS_TOOL=true
ENABLE_CALCULATOR_TOOL=true

##############################################################
# Search
##############################################################
SEARCH_PROVIDER=serper               # serper | tavily | duckduckgo

SERPER_API_KEY=
TAVILY_API_KEY=

##############################################################
# Weather
##############################################################
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

##############################################################
# News
##############################################################
NEWSAPI_API_KEY=
NEWSAPI_BASE_URL=https://newsapi.org/v2

##############################################################
# HTTP
##############################################################
HTTP_TIMEOUT=30

MAX_RETRIES=3
RETRY_DELAY=2

USER_AGENT=AI-Agent-Platform/1.0

##############################################################
# CLI
##############################################################
CLI_THEME=dark

CLI_STREAMING=true

CLI_SHOW_TOOL_CALLS=true
CLI_SHOW_THINKING=false

##############################################################
# Logging
##############################################################
LOG_LEVEL=INFO
LOG_FORMAT=rich                      # rich | json | plain

LOG_FILE=./logs/app.log

##############################################################
# LangSmith
##############################################################
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=AI-Agent-Platform

##############################################################
# Session
##############################################################
SESSION_TTL_HOURS=24
MAX_SESSIONS=100

##############################################################
# Agent Configuration
##############################################################
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOOL_CALLS=20
AGENT_TIMEOUT=300